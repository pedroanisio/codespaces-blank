        "state": "approved"
      },
      "logline": "A lone radio operator on a dying station receives a signal — not distress, but an invitation.",
      "synopsis": "Two-act 30-second micro-short. Act 1: isolation. Act 2: contact and hope.",
      "themes": [
        "isolation",
        "hope"
      ],
      "tone": [
        "melancholic",
        "hopeful"
      ],
      "beats": [
        {
          "beatId": "beat.isolation",
          "name": "Isolation",
          "order": 1,
          "description": "MIRA keeps vigil alone in the dying communications bay.",
          "emotionalObjective": "melancholy"
        },
        {
          "beatId": "beat.contact",
          "name": "Contact",
          "order": 2,
          "description": "The QRA device lights up. MIRA hears the invitation.",
          "emotionalObjective": "hope"
        }
      ]
    },
    "script": {
      "id": "script.demo-30s.v1",
      "logicalId": "script.demo-30s",
      "entityType": "script",
      "name": "Demo Script",
      "version": {
        "number": "1.0.0",
        "state": "approved"
      },
      "format": "fountain",
      "segments": [
        {
          "segmentId": "seg.heading1",
          "order": 1,
          "segmentType": "scene_heading",
          "text": "INT. HELIX-7 COMMUNICATIONS BAY — NIGHT",
          "sceneRef": {
            "id": "scene.isolation.v1"
          }
        },
        {
          "segmentId": "seg.action1",
          "order": 2,
          "segmentType": "action",
          "text": "Emergency lights pulse amber. MIRA sits alone at a console covered in static.",
          "sceneRef": {
            "id": "scene.isolation.v1"
          }
        },
        {
          "segmentId": "seg.heading2",
          "order": 3,
          "segmentType": "scene_heading",
          "text": "INT. HELIX-7 COMMUNICATIONS BAY — CONTINUOUS",
          "sceneRef": {
            "id": "scene.contact.v1"
          }
        },
        {
          "segmentId": "seg.action2",
          "order": 4,
          "segmentType": "action",
          "text": "The QRA device CHIRPS. Blue light floods the room. MIRA snaps forward.",
          "sceneRef": {
            "id": "scene.contact.v1"
          }
        },
        {
          "segmentId": "seg.dialogue1",
          "order": 5,
          "segmentType": "dialogue",
          "text": "They know we're here.",
          "speakerRef": {
            "id": "char.mira.v1"
          },
          "sceneRef": {
            "id": "scene.contact.v1"
          }
        }
      ]
    },
