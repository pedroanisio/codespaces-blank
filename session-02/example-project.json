      "version": { "number": "1.0.0", "state": "approved" },
      "beats": [
        {
          "beatId": "beat.act1",
          "title": "Isolation",
          "synopsis": "MIRA, the last operator on the dying Helix-7 station, maintains her vigil alone in the communications bay.",
          "emotionalObjective": "melancholy",
          "positionHint": "opening"
        },
        {
          "beatId": "beat.act2",
          "title": "Contact",
          "synopsis": "An anomalous signal arrives — the QRA device lights up for the first time in months.",
          "emotionalObjective": "wonder",
          "positionHint": "midpoint"
        },
        {
          "beatId": "beat.act3",
          "title": "Transmission",
          "synopsis": "MIRA deciphers the message. It is not distress — it is an invitation.",
          "emotionalObjective": "hope",
          "positionHint": "climax"
        }
      ]
    },
    "script": {
      "id": "script.the-last-signal.v1",
      "logicalId": "script.the-last-signal",
      "entityType": "script",
      "name": "The Last Signal — Script",
      "version": { "number": "1.0.0", "state": "approved" },
      "segments": [
        {
          "segmentId": "seg.s1",
          "segmentType": "scene_heading",
          "text": "INT. HELIX-7 COMMUNICATIONS BAY — NIGHT",
          "sceneRef": "scene.act1"
        },
        {
          "segmentId": "seg.s2",
          "segmentType": "action",
          "text": "Emergency lights pulse amber. MIRA sits at a console covered in static.",
          "sceneRef": "scene.act1"
        },
        {
          "segmentId": "seg.s3",
          "segmentType": "scene_heading",
          "text": "INT. HELIX-7 COMMUNICATIONS BAY — CONTINUOUS",
          "sceneRef": "scene.act2"
        },
        {
          "segmentId": "seg.s4",
          "segmentType": "action",
          "text": "The QRA device CHIRPS. MIRA snaps forward, hands trembling over the controls.",
          "sceneRef": "scene.act2"
        },
        {
          "segmentId": "seg.s5",
          "segmentType": "scene_heading",
          "text": "INT. HELIX-7 COMMUNICATIONS BAY — MOMENTS LATER",
          "sceneRef": "scene.act3"
        },
        {
          "segmentId": "seg.s6",
          "segmentType": "dialogue",
          "text": "They know we're here.",
          "characterRef": "char.mira",
          "sceneRef": "scene.act3"
        }
      ]
    },
    "directorInstructions": {
      "id": "di.the-last-signal.v1",
      "logicalId": "di.the-last-signal",
      "entityType": "directorInstructions",
      "name": "The Last Signal — Director Instructions",
      "version": { "number": "1.0.0", "state": "approved" },
      "visionStatement": "A meditation on isolation and hope in deep space. Visual language must feel claustrophobic in Acts 1–2, then open and luminous in Act 3.",
      "mustHaves": [
        "amber emergency lighting throughout Acts 1–2",
        "character face consistency across all close-up shots",
        "180-degree rule respected in the MIRA/QRA two-shot sequence"
      ],
      "mustAvoid": [
        "bright natural or daylight sources",
        "cheerful expressions before Act 3"
      ],
      "editingLanguage": "Deliberate pacing with cuts on action. Dissolve reserved for the Act 3 revelation moment only.",
      "colorDirection": "Amber/dark palette in Acts 1–2. Warm green console glow grows through Act 3.",
      "qualityRules": [
        { "name": "Temporal consistency", "id": "qr.temporal", "severity": "error" },
        { "name": "180-degree rule", "id": "qr.180deg", "severity": "error" }
      ],
      "targetedNotes": []
    }
  },

