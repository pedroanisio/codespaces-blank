  "director_notes": {
    "overall_vision": "Intimate and claustrophobic. Every frame should feel like the station is breathing its last. The signal must feel miraculous, not supernatural — earned through Mira's 60 days of silence.",
    "tone_and_mood": "Quiet dread giving way to fragile hope. Think Arrival meets Gravity, but stripped to the bone.",
    "target_audience": "Sci-fi short-film audiences, festival circuit, YouTube cinematic shorts.",
    "style_references": [
      "Arrival (2016) — colour palette and stillness",
      "Gravity (2013) — space station production design",
      "Moon (2009) — single character isolation"
    ],
    "quality_rules": [
      "No lens flare in Act 1 — reserve for the signal moment only",
      "Mira's face must remain consistent across all close-ups",
      "Station interior colour temperature must never exceed 3200K (cold blue-green)"
    ],
    "per_scene_overrides": {
      "scene-act1-isolation": {
        "vision": "Static wide shots. No camera movement until Act 2.",
        "camera_style": "locked-off, slight dutch tilt on final shot",
        "mood": "resigned"
      },
      "scene-act2-signal": {
        "vision": "Tight close-ups. Handheld for the static burst.",
        "camera_style": "handheld push in on face",
        "mood": "shock, disbelief"
      },
      "scene-act3-choice": {
        "vision": "Extreme close-up on hand. Then black. Then the LED.",
        "camera_style": "extreme close-up, static, then macro on LED",
        "mood": "catharsis"
      }
    }
  },

